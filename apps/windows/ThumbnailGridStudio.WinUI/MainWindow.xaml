<Window
    x:Class="ThumbnailGridStudio.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ThumbnailGridStudio.WinUI.Models"
    Title="Thumbnail Grid Studio">
    <Grid
        AllowDrop="True"
        DragOver="RootDragOver"
        Drop="RootDrop"
        RequestedTheme="Dark"
        Background="#121212">
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="CustomTitleBar"
            Grid.Row="0"
            Background="#1D1D1F"
            BorderBrush="#313136"
            BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock
                    Margin="14,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Text="Thumbnail Grid Studio"
                    FontSize="18"
                    FontWeight="SemiBold" />

                <StackPanel
                    x:Name="TitleBarCenterButtons"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
                    <Button
                        Width="42"
                        Height="34"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="ClearClick"
                        IsEnabled="{x:Bind ViewModel.CanClear, Mode=OneWay}">
                        <FontIcon Glyph="&#xE74D;" FontSize="16" />
                    </Button>
                    <Button
                        Width="42"
                        Height="34"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="ExportAllClick"
                        IsEnabled="{x:Bind ViewModel.CanExport, Mode=OneWay}">
                        <PathIcon
                            Data="M 2 1 L 2 15 L 14 8 Z"
                            Foreground="#2ECC71"
                            Width="16"
                            Height="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="#2D2D30"
                BorderBrush="#3A3A40"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="10,10,10,8" Spacing="8">
                        <ProgressBar
                            Height="6"
                            Minimum="0"
                            Maximum="100"
                            Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}"
                            Visibility="{x:Bind BoolToVisibility(ViewModel.IsWorking), Mode=OneWay}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                            FontSize="12"
                            Foreground="#BDBDBD"
                            Visibility="{x:Bind BoolToVisibility(ViewModel.IsWorking), Mode=OneWay}" />
                    </StackPanel>

                    <ListView
                        Grid.Row="1"
                        Margin="8,0,8,0"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{x:Bind ViewModel.Videos, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedVideo, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:VideoItem">
                                <StackPanel Spacing="2" Padding="6,6">
                                    <TextBlock
                                        Text="{x:Bind FileName}"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{x:Bind FileSizeText}"
                                        FontSize="11"
                                        Foreground="#BFBFBF"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{x:Bind StatusText}"
                                        FontSize="11"
                                        Foreground="#8F8F8F"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border
                        Grid.Row="2"
                        Padding="10,8"
                        BorderBrush="#3A3A40"
                        BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                            <Button
                                Width="40"
                                Height="34"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="AddVideosClick"
                                IsEnabled="{x:Bind ViewModel.CanAdd, Mode=OneWay}">
                                <FontIcon Glyph="&#xE710;" FontSize="15" />
                            </Button>
                            <Button
                                Width="40"
                                Height="34"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="RemoveSelectedClick"
                                IsEnabled="{x:Bind ViewModel.CanRemove, Mode=OneWay}">
                                <FontIcon Glyph="&#xE74D;" FontSize="15" />
                            </Button>
                            <Button
                                Width="40"
                                Height="34"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="OpenSettingsClick">
                                <FontIcon Glyph="&#xE713;" FontSize="15" />
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="18">
                <Border
                    Background="#2A2B2F"
                    BorderBrush="#3A3B40"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                    <Border
                        Background="#1F232D"
                        BorderBrush="#3E4148"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                CornerRadius="10"
                                BorderBrush="#3B3E46"
                                BorderThickness="1"
                                Background="#191B20">
                                <Grid>
                                    <Image
                                        Stretch="Uniform"
                                        Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}"
                                        Visibility="{x:Bind BoolToVisibility(ViewModel.HasPreview), Mode=OneWay}" />
                                    <TextBlock
                                        x:Name="NoPreviewText"
                                        Text="Keine Vorschau"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#9FA4AD"
                                        FontSize="16"
                                        Visibility="{x:Bind BoolToVisibilityInverse(ViewModel.HasPreview), Mode=OneWay}" />
                                </Grid>
                            </Border>

                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind ViewModel.LastError, Mode=OneWay}"
                                Foreground="#FF907B"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind StringToVisibility(ViewModel.LastError), Mode=OneWay}" />
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>


